# Copy to `.env.local` and fill values. Never commit `.env.local`.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth (Phase 8+)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# MongoDB (Phase 7+)
MONGODB_URI=

# CKEditor — use same key as learning-project (see learning-project/.env.local); trial/production per vendor terms
NEXT_PUBLIC_CKEDITOR_LICENSE_KEY=

# Cloudinary (when uploads are wired)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SSLCommerz (Phase 10)
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_SANDBOX_URL=https://sandbox.sslcommerz.com
SSLCOMMERZ_LIVE_URL=https://securepay.sslcommerz.com
SSLCOMMERZ_ENVIRONMENT=sandbox
SSLCOMMERZ_SUCCESS_URL=http://localhost:3000/payment/success
SSLCOMMERZ_FAIL_URL=http://localhost:3000/payment/fail
SSLCOMMERZ_CANCEL_URL=http://localhost:3000/payment/cancel
SSLCOMMERZ_IPN_URL=http://localhost:3000/payment/ipn

# Mock vs real API (Phase 2+ integration toggle)
NEXT_PUBLIC_USE_MOCK_API=true

# Optional: empty catalog success body (contract-shaped) — for empty-state UI checks
NEXT_PUBLIC_MOCK_PUBLIC_COURSES_EMPTY=false
